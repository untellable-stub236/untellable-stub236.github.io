{
  "name": "celoht",
  "version": "1.0.0",
  "private": true,
  "description": "CeloHT — Web3 Education, Agent Network, Financial Inclusion & Reforestation.",
  "author": "CeloHT Core Team",
  "license": "MIT",

  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "clean": "rm -rf .next node_modules",
    "generate:sitemap": "next-sitemap",
    "generate:docs": "typedoc --out docs src",
    "check:links": "lychee .",
    "check:accessibility": "accesslint",
    "check:security": "echo \"Security checks handled by GitHub CodeQL\"",
    "check:performance": "echo \"Performance handled by Lighthouse CI\"",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },

  "dependencies": {
    "next": "14.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "gray-matter": "4.0.3",
    "chart.js": "4.4.0",
    "react-chartjs-2": "5.2.0",
    "next-sitemap": "4.2.3",
    "typedoc": "0.25.7",
    "tailwindcss": "3.4.1",
    "postcss": "8.4.31",
    "autoprefixer": "10.4.16"
  },

  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/jest": "29.5.5",
    "typescript": "5.3.3",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "prettier": "3.1.1",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "husky": "8.0.3",
    "lint-staged": "15.2.0"
  },

  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  },

  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "npx commitlint --edit $1",
      "pre-push": "npm run test"
    }
  },

  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleFileExtensions": ["ts", "tsx", "js"],
    "testPathIgnorePatterns": ["/node_modules/", "/.next/"]
  },

  "browserslist": [
    "defaults",
    "not IE 11",
    "maintained node versions"
  ],

  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}
